{
  "name": "bulk-shot",
  "displayName": "BulkShot",
  "version": "0.0.1",
  "description": "BulkShot — bulk AI image generation queue for ChatGPT and Gemini, right inside your browser.",
  "author": "suryansh2846code",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "postinstall": "node scripts/copy-worker.js",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "lucide-react": "^0.378.0",
    "pdfjs-dist": "^4.3.136",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sharp": "^0.35.1",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "wrangler": "^4.112.0"
  },
  "manifest": {
    "permissions": [
      "storage",
      "unlimitedStorage",
      "tabs",
      "downloads",
      "notifications",
      "offscreen"
    ],
    "host_permissions": [
      "https://chatgpt.com/*",
      "https://gemini.google.com/*"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "pdf.worker.min.*.js"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ]
  }
}
